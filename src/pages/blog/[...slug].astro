---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Icon from '../../components/Icon.astro';
import { site } from '../../data/site';
import { withBase, absoluteUrl } from '../../utils/base';

export const getStaticPaths = (async () => {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);

const url = absoluteUrl(`/blog/${post.id}`);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: { '@type': 'Person', name: post.data.author },
  publisher: { '@type': 'Person', name: site.name },
  mainEntityOfPage: url,
  inLanguage: 'pl-PL',
  image: absoluteUrl(site.defaultOgImage),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: absoluteUrl('/') },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: absoluteUrl('/blog') },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: url },
  ],
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  path={`/blog/${post.id}`}
  ogType="article"
  jsonLd={[articleSchema, breadcrumbSchema]}
>
  <PageHero
    eyebrow={post.data.category}
    title={post.data.title}
    breadcrumbs={[{ label: 'Blog', href: '/blog' }, { label: post.data.title }]}
  >
    <p class="post-meta">
      <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
      <span aria-hidden="true">·</span>
      <span>{post.data.author}</span>
    </p>
  </PageHero>

  <section class="section">
    <article class="container container--prose prose">
      <Content />
    </article>

    <div class="container container--prose post-footer">
      {
        post.data.tags.length > 0 && (
          <ul role="list" class="post-tags">
            {post.data.tags.map((t) => <li class="pill">#{t}</li>)}
          </ul>
        )
      }
      <a href={withBase('/blog')} class="arrow-link back">
        <Icon name="arrow-right" class="flip" /> Wróć do bloga
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .post-meta {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    margin-top: var(--space-s);
    color: var(--color-on-deep-muted);
    font-size: var(--step--1);
  }
  .post-footer {
    margin-top: var(--space-xl);
    padding-top: var(--space-l);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-m);
    align-items: center;
    justify-content: space-between;
  }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .back :global(.flip) { transform: rotate(180deg); }
</style>
