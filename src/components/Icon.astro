---
/**
 * Zestaw ikon jako inline SVG (bez zewnętrznych zależności i font-ikon).
 * Wszystkie ikony domyślnie dekoracyjne (aria-hidden). Podaj `title`, aby
 * ikona była opisana dla technologii asystujących.
 */
interface Props {
  name: keyof typeof paths | string;
  size?: number | string;
  title?: string;
  class?: string;
  stroke?: number;
}

const { name, size = '1.25em', title, class: className, stroke = 1.7 } = Astro.props;

const paths: Record<string, string> = {
  menu: '<line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>',
  close: '<line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/>',
  'arrow-right': '<line x1="4" y1="12" x2="20" y2="12"/><polyline points="14 6 20 12 14 18"/>',
  'arrow-up-right': '<line x1="7" y1="17" x2="17" y2="7"/><polyline points="8 7 17 7 17 16"/>',
  'chevron-down': '<polyline points="6 9 12 15 18 9"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><polyline points="3 7 12 13 21 7"/>',
  phone: '<path d="M5 4h4l2 5-2.5 1.5a11 11 0 0 0 5 5L20 13l-1 4h-4A11 11 0 0 1 5 4Z"/>',
  youtube: '<rect x="2.5" y="5.5" width="19" height="13" rx="4"/><polygon points="10 9.2 15.5 12 10 14.8" fill="currentColor" stroke="none"/>',
  sun: '<circle cx="12" cy="12" r="4"/><line x1="12" y1="2.5" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="21.5"/><line x1="2.5" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="21.5" y2="12"/><line x1="5.1" y1="5.1" x2="6.9" y2="6.9"/><line x1="17.1" y1="17.1" x2="18.9" y2="18.9"/><line x1="18.9" y1="5.1" x2="17.1" y2="6.9"/><line x1="6.9" y1="17.1" x2="5.1" y2="18.9"/>',
  moon: '<path d="M20 14.5A8 8 0 1 1 9.5 4a6.3 6.3 0 0 0 10.5 10.5Z"/>',
  quote: '<path d="M10 7c-3 1-5 3.5-5 7v3h6v-6H8c0-2 1-3 3-3.5Zm9 0c-3 1-5 3.5-5 7v3h6v-6h-3c0-2 1-3 3-3.5Z" fill="currentColor" stroke="none"/>',
  book: '<path d="M4 5a2 2 0 0 1 2-2h13v16H6a2 2 0 0 0-2 2Z"/><line x1="8" y1="7" x2="15" y2="7"/><line x1="8" y1="11" x2="15" y2="11"/>',
  play: '<circle cx="12" cy="12" r="9"/><polygon points="10 8.5 16 12 10 15.5" fill="currentColor" stroke="none"/>',
  calendar: '<rect x="3.5" y="5" width="17" height="16" rx="2"/><line x1="3.5" y1="9" x2="20.5" y2="9"/><line x1="8" y1="3" x2="8" y2="6"/><line x1="16" y1="3" x2="16" y2="6"/>',
  users: '<circle cx="9" cy="8" r="3.2"/><path d="M3.5 20a5.5 5.5 0 0 1 11 0"/><path d="M16 5.2a3.2 3.2 0 0 1 0 6.1"/><path d="M17 15.2A5.5 5.5 0 0 1 20.5 20"/>',
  check: '<polyline points="4 12.5 9.5 18 20 6"/>',
  info: '<circle cx="12" cy="12" r="9"/><line x1="12" y1="11" x2="12" y2="16.5"/><circle cx="12" cy="7.8" r="0.6" fill="currentColor" stroke="none"/>',
  heart: '<path d="M12 20s-7-4.4-9.2-8.6C1.2 8 3 4.5 6.4 4.5c2 0 3.2 1.2 3.6 2 .4-.8 1.6-2 3.6-2 3.4 0 5.2 3.5 3.6 6.9C19 15.6 12 20 12 20Z"/>',
  compass: '<circle cx="12" cy="12" r="9"/><polygon points="15.5 8.5 11 11 8.5 15.5 13 13" fill="currentColor" stroke="none"/>',
  feather: '<path d="M20 4c-6 0-12 3-14 11l-2 5"/><path d="M20 4c0 6-3 11-9 12l-5 1"/><line x1="8" y1="14" x2="14" y2="8"/>',
  location: '<path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/>',
  link: '<path d="M9 15l6-6"/><path d="M11 6.5 13 4.5a4 4 0 0 1 5.7 5.7l-2 2"/><path d="M13 17.5 11 19.5a4 4 0 0 1-5.7-5.7l2-2"/>',
};

const glyph = paths[name] ?? paths.info;
const sizeVal = typeof size === 'number' ? `${size}px` : size;
---

<svg
  class={className}
  width={sizeVal}
  height={sizeVal}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={stroke}
  stroke-linecap="round"
  stroke-linejoin="round"
  role={title ? 'img' : undefined}
  aria-hidden={title ? undefined : 'true'}
  aria-label={title}
  focusable="false"
  set:html={(title ? `<title>${title}</title>` : '') + glyph}
/>
