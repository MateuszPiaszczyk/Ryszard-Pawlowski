---
import Icon from './Icon.astro';
import { mainNav } from '../data/navigation';
import { site } from '../data/site';
import { withBase } from '../utils/base';

// Porównujemy ścieżki z uwzględnieniem bazy: bieżący pathname zawiera bazę
// (np. /Ryszard-Pawlowski/o-mnie), więc href-y też przepuszczamy przez withBase.
const norm = (p: string) => p.replace(/\/+$/, '') || '/';
const pathname = norm(new URL(Astro.request.url).pathname);
const rootPath = norm(withBase('/'));
const isActive = (href: string) => {
  const target = norm(withBase(href));
  return target === rootPath
    ? pathname === rootPath
    : pathname === target || pathname.startsWith(target + '/');
};
---

<header class="site-header" data-site-header>
  <div class="container site-header__inner">
    <a href={withBase('/')} class="brand" aria-label={`${site.name} — strona główna`}>
      <span class="brand__mark" aria-hidden="true">
        <svg viewBox="0 0 64 64" width="40" height="40">
          <rect width="64" height="64" rx="14" fill="#12202c"></rect>
          <path
            d="M32 13c4.6 6.2 9.4 10.9 9.4 18.2 0 6.1-4.2 10.6-9.4 10.6s-9.4-4.5-9.4-10.6c0-3.4 1.6-6 3.7-8.6 0 2.9 1.3 4.6 3 4.6 2 0 2.9-1.8 2.4-4.6-.6-3.3-1.4-6.2 .3-9.6z"
            fill="#d9b978"></path>
        </svg>
      </span>
      <span class="brand__text">
        <span class="brand__name">Ks. Ryszard Pawłowski</span>
        <span class="brand__tag">Rekolekcje ignacjańskie</span>
      </span>
    </a>

    <nav class="nav-desktop" aria-label="Nawigacja główna">
      <ul role="list" class="nav-desktop__list">
        {
          mainNav.map((item) => (
            <li>
              <a
                href={withBase(item.href)}
                class="nav-link"
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-actions">
      <a
        class="icon-btn"
        href={site.social.youtube}
        target="_blank"
        rel="noopener"
        aria-label="Kanał YouTube ks. Ryszarda Pawłowskiego (otwiera się w nowej karcie)"
      >
        <Icon name="youtube" />
      </a>

      <button
        type="button"
        class="icon-btn"
        data-theme-toggle
        aria-label="Przełącz motyw jasny/ciemny"
        aria-pressed="false"
      >
        <span class="theme-icon theme-icon--sun"><Icon name="sun" /></span>
        <span class="theme-icon theme-icon--moon"><Icon name="moon" /></span>
      </button>

      <details class="nav-mobile" data-nav-mobile>
        <summary class="icon-btn nav-mobile__toggle" aria-label="Otwórz menu">
          <span class="nav-mobile__open"><Icon name="menu" /></span>
          <span class="nav-mobile__close"><Icon name="close" /></span>
        </summary>
        <div class="nav-mobile__panel">
          <nav aria-label="Nawigacja mobilna">
            <ul role="list" class="nav-mobile__list">
              {
                mainNav.map((item) => (
                  <li>
                    <a
                      href={withBase(item.href)}
                      class="nav-mobile__link"
                      aria-current={isActive(item.href) ? 'page' : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
          <a class="btn btn--sm nav-mobile__cta" href={site.social.youtube} target="_blank" rel="noopener">
            <Icon name="youtube" /> YouTube
          </a>
        </div>
      </details>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background: color-mix(in srgb, var(--color-bg) 82%, transparent);
    backdrop-filter: saturate(140%) blur(12px);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur) var(--ease-out),
      background-color var(--dur) var(--ease-out);
  }
  .site-header[data-scrolled] {
    border-bottom-color: var(--color-border);
    box-shadow: var(--shadow-xs);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-s);
    min-height: var(--header-h);
  }

  /* --- Marka / logo --- */
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--color-heading);
    border-radius: var(--radius-sm);
  }
  .brand__mark {
    display: grid;
    place-items: center;
    filter: drop-shadow(var(--shadow-xs));
    flex: none;
  }
  .brand__mark svg { border-radius: 12px; }
  .brand__text { display: flex; flex-direction: column; line-height: 1.1; }
  .brand__name {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.18rem;
    letter-spacing: -0.01em;
  }
  .brand__tag {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-primary);
    font-weight: 600;
  }

  /* --- Nawigacja desktop --- */
  .nav-desktop { display: none; }
  .nav-desktop__list {
    display: flex;
    align-items: center;
    gap: clamp(0.25rem, 1.4vw, 1.1rem);
  }
  .nav-link {
    display: inline-block;
    padding: 0.55rem 0.7rem;
    font-size: 0.98rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-text);
    border-radius: var(--radius-sm);
    position: relative;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0.7rem;
    right: 0.7rem;
    bottom: 0.35rem;
    height: 2px;
    border-radius: 2px;
    background: var(--color-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur) var(--ease-out);
  }
  .nav-link:hover { color: var(--color-primary-strong); }
  .nav-link:hover::after,
  .nav-link[aria-current='page']::after { transform: scaleX(1); }
  .nav-link[aria-current='page'] { color: var(--color-primary-strong); font-weight: 600; }

  /* --- Akcje --- */
  .header-actions { display: flex; align-items: center; gap: 0.35rem; }
  .icon-btn {
    display: inline-grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-pill);
    color: var(--color-text);
    text-decoration: none;
    background: transparent;
    transition: background-color var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
  }
  .icon-btn:hover { background: var(--color-bg-subtle); color: var(--color-primary-strong); }
  .icon-btn::-webkit-details-marker { display: none; }

  /* Theme toggle — pokaż właściwą ikonę */
  [data-theme-toggle] { position: relative; }
  .theme-icon { display: grid; place-items: center; }
  .theme-icon--moon { display: none; }
  :global(:root[data-theme='dark']) .theme-icon--sun { display: none; }
  :global(:root[data-theme='dark']) .theme-icon--moon { display: grid; }
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .theme-icon--sun { display: none; }
    :global(:root:not([data-theme='light'])) .theme-icon--moon { display: grid; }
  }

  /* --- Nawigacja mobilna (natywny <details> — działa też bez JS) --- */
  .nav-mobile { position: relative; }
  .nav-mobile__toggle { list-style: none; }
  .nav-mobile__toggle::marker,
  .nav-mobile__toggle::-webkit-details-marker { display: none; }
  .nav-mobile__close { display: none; }
  .nav-mobile[open] .nav-mobile__open { display: none; }
  .nav-mobile[open] .nav-mobile__close { display: grid; }

  .nav-mobile__panel {
    position: fixed;
    inset: var(--header-h) 0 auto 0;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-lg);
    padding: var(--space-s) var(--gutter) var(--space-l);
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    max-height: calc(100dvh - var(--header-h));
    overflow-y: auto;
    animation: panel-in var(--dur) var(--ease-out);
  }
  @keyframes panel-in {
    from { opacity: 0; transform: translateY(-0.5rem); }
    to { opacity: 1; transform: none; }
  }
  .nav-mobile__list { display: flex; flex-direction: column; }
  .nav-mobile__link {
    display: block;
    padding: 0.95rem 0.5rem;
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-heading);
    border-bottom: 1px solid var(--color-border);
  }
  .nav-mobile__link[aria-current='page'] { color: var(--color-primary-strong); }
  .nav-mobile__cta { align-self: flex-start; margin-top: var(--space-2xs); }

  @media (min-width: 60rem) {
    .nav-desktop { display: block; }
    .nav-mobile { display: none; }
  }
</style>

<script>
  // Progresywne ulepszenie natywnego <details>: zamykanie klawiszem Escape,
  // po kliknięciu w link, po kliknięciu poza panelem oraz blokada przewijania.
  const details = document.querySelector<HTMLDetailsElement>('[data-nav-mobile]');
  if (details) {
    const summary = details.querySelector('summary');
    const close = () => {
      if (!details.open) return;
      details.open = false;
      summary?.setAttribute('aria-label', 'Otwórz menu');
      document.body.style.removeProperty('overflow');
    };
    details.addEventListener('toggle', () => {
      const open = details.open;
      summary?.setAttribute('aria-label', open ? 'Zamknij menu' : 'Otwórz menu');
      document.body.style.overflow = open ? 'hidden' : '';
    });
    details.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
    document.addEventListener('click', (e) => {
      if (details.open && !details.contains(e.target as Node)) close();
    });
  }

  // Cień nagłówka po przewinięciu.
  const header = document.querySelector('[data-site-header]');
  const onScroll = () => {
    if (window.scrollY > 8) header?.setAttribute('data-scrolled', '');
    else header?.removeAttribute('data-scrolled');
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
