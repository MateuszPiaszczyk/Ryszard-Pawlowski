---
/**
 * Kompletne meta dane SEO: tytuł, opis, canonical, Open Graph, Twitter Cards
 * oraz dane strukturalne JSON-LD (schema.org).
 */
import { site } from '../data/site';
import { absoluteUrl } from '../utils/base';

interface Props {
  title: string;
  description?: string;
  /** Ścieżka względna (np. "/o-mnie") — canonical i og:url budowane automatycznie. */
  path?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article' | 'profile';
  noindex?: boolean;
  /** Dowolna liczba obiektów JSON-LD wstrzykiwanych do <head>. */
  jsonLd?: Record<string, unknown>[];
  /** Nie dołączaj sufiksu z nazwą serwisu do tytułu. */
  bareTitle?: boolean;
}

const {
  title,
  description = site.description,
  path = new URL(Astro.request.url).pathname,
  ogImage = site.defaultOgImage,
  ogImageAlt = 'Ks. Ryszard Pawłowski — rekolekcje ignacjańskie',
  ogType = 'website',
  noindex = false,
  jsonLd = [],
  bareTitle = false,
} = Astro.props;

// Canonical i OG budujemy przez absoluteUrl (origin z pola `site` + adres bazowy).
// `path` może być czysty (np. "/o-mnie") albo już z bazą (domyślnie z Astro.url) —
// absoluteUrl normalizuje oba przypadki.
const canonical = absoluteUrl(path).replace(/\/$/, '') || absoluteUrl('/');
const ogImageUrl = /^https?:\/\//.test(ogImage) ? ogImage : absoluteUrl(ogImage);
const fullTitle = bareTitle ? title : `${title} — ${site.name}`;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

{
  noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta name="robots" content="index, follow, max-image-preview:large" />
  )
}
<meta name="author" content={site.name} />
<meta name="theme-color" content={site.themeColor} />

{/* Open Graph */}
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={site.legalName} />
<meta property="og:locale" content={site.locale} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:secure_url" content={ogImageUrl} />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt} />

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={ogImageAlt} />

{
  jsonLd.map((data) => (
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(data)}
    />
  ))
}
